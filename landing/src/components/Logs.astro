---
import { Badge } from "@/components/ui/badge"
import TerminalBlock from "@/components/TerminalBlock.astro"
import { Terminal } from "lucide-react"

const lines = [
  { badge: "INFO" as const, content: "14:32:01  starting mole, version 0.1.0" },
  { badge: "INFO" as const, content: "14:32:01  connected to dev (workstation:22) via ssh-agent" },
  { badge: "INFO" as const, content: "14:32:02  auto-discover: 3 remote ports found" },
  { badge: "FORWARD" as const, content: "localhost:3000  →  workstation:3000" },
  { badge: "FORWARD" as const, content: "localhost:5173  →  workstation:5173" },
  { badge: "FORWARD" as const, content: "localhost:8080  →  workstation:8080" },
  { badge: "INFO" as const, content: "14:32:08  re-discover: 4 remote ports found" },
  { badge: "FORWARD" as const, content: "localhost:9090  →  workstation:9090" },
  { badge: "UNFWD" as const, content: "localhost:8080  pruned (remote closed)" },
  { badge: "INFO" as const, content: "14:32:14  ssh tunnel healthy" },
  { badge: "INFO" as const, content: "14:32:20  forwarded connection on :3000 (×12)" },
]
---

<section id="logs" data-reveal class="scroll-mt-nav relative py-24">
  <div class="relative z-10 mx-auto max-w-5xl px-6">
    <div class="mb-10 flex flex-col items-center gap-3 text-center">
      <Badge variant="outline" className="gap-1.5">
        <Terminal className="text-primary" />
        Logs
      </Badge>
      <h2 class="font-mono text-3xl font-bold text-foreground">
        Colourised, structured, skimmable
      </h2>
      <p class="max-w-2xl text-base text-muted-foreground">
        Every line gets a colour-graded level badge, a dimmed timestamp, and repeated events collapse to a single line with a (×N) counter.
      </p>
    </div>

    <TerminalBlock title="mole logs" animated={false} showCaret={false} lines={lines} />

    <p class="mx-auto mt-6 max-w-3xl text-center text-base text-muted-foreground">
      mole logs renders the daemon's structured log with coloured level badges, a
      distinct green <span class="font-mono text-terminal-green">FORWARD</span>
      badge when a port starts forwarding and a burnt-orange
      <span class="font-mono text-terminal-orange">UNFWD</span> badge when a dead
      remote port is pruned, dimmed timestamps, and
      <span class="font-mono">(×N)</span> collapsing of repeated lines.
    </p>
  </div>
</section>
