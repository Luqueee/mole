---
import { Card, CardHeader } from "@/components/ui/card"
import PortChip from "@/components/PortChip.astro"

const clients = ["browser", "curl", "whatever"]
const remotes = ["workstation:3000", "workstation:5173", "workstation:8080"]
const ports = [
  { local: "localhost:3000", remote: "workstation:3000" },
  { local: "localhost:5173", remote: "workstation:5173" },
  { local: "localhost:8080", remote: "workstation:8080" },
]
---

<section id="diagram" data-reveal class="scroll-mt-nav relative py-24">
  <div class="relative z-10 mx-auto max-w-5xl px-6">
    <div class="grid grid-cols-1 items-center gap-6 md:grid-cols-[1fr_auto_1fr]">
      <!-- Left: clients -->
      <Card className="bg-card border border-border">
        <CardHeader className="gap-3">
          <div class="font-mono text-xs text-muted-foreground">clients</div>
          <div class="flex flex-col gap-2 font-mono text-foreground">
            {clients.map((c) => (
              <span class="flex items-center gap-2">
                <span class="size-1.5 rounded-full bg-terminal-cyan"></span>
                {c}
              </span>
            ))}
          </div>
        </CardHeader>
      </Card>

      <!-- Center: tunnel -->
      <div class="relative flex flex-col items-center justify-center gap-3 px-4 py-2">
        <span class="font-mono text-xs uppercase tracking-widest text-muted-foreground">one SSH connection</span>
        <div class="relative flex flex-col items-center gap-2">
          <div class="absolute left-1/2 top-0 bottom-0 hidden w-px -translate-x-1/2 border-l border-dashed border-primary/40 md:block" aria-hidden="true"></div>
          <div aria-hidden="true" class="absolute left-1/2 top-0 hidden size-1.5 -translate-x-1/2 rounded-full bg-terminal-green shadow-[0_0_8px_var(--glow-primary)] md:block" style="animation: flow-dot 2.4s linear infinite;"></div>
          {ports.map((p) => (
            <PortChip local={p.local} remote={p.remote} />
          ))}
        </div>
        <div class="mt-2 inline-flex items-center gap-1.5 rounded-full border border-border bg-card px-2.5 py-1 font-mono text-[10px] text-muted-foreground">
          <span class="size-1.5 rounded-full bg-terminal-green"></span>mole
        </div>
      </div>

      <!-- Right: remote -->
      <Card className="bg-card border border-border">
        <CardHeader className="gap-3">
          <div class="font-mono text-xs text-muted-foreground">remote host</div>
          <div class="flex flex-col gap-2 font-mono text-foreground">
            {remotes.map((r) => (
              <span class="flex items-center gap-2">
                <span class="size-1.5 rounded-full bg-terminal-green"></span>
                {r}
              </span>
            ))}
          </div>
        </CardHeader>
      </Card>
    </div>

    <p class="mt-8 text-center text-sm text-muted-foreground">
      mole runs here, on your laptop — ssh-agent or <code class="font-mono text-foreground">~/.ssh/id_*</code>
    </p>
  </div>
</section>
