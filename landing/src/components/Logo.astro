---
import { cn } from "@/lib/utils"

interface Props {
  size?: number
  withWordmark?: boolean
  class?: string
}

const { size = 28, withWordmark = true, class: className } = Astro.props
---

<a href="/" class={cn("inline-flex items-center gap-2 text-primary", className)}>
  <svg viewBox="0 0 24 24" width={size} height={size} fill="currentColor" aria-hidden="true">
    <ellipse cx="12" cy="14" rx="9" ry="7.5"></ellipse>
    <circle cx="7" cy="6.5" r="2"></circle>
    <circle cx="17" cy="6.5" r="2"></circle>
    <circle cx="9.5" cy="13" r="0.8" fill="hsl(213 27% 7%)"></circle>
    <circle cx="14.5" cy="13" r="0.8" fill="hsl(213 27% 7%)"></circle>
    <path d="M11 16.5 Q12 17.5 13 16.5" stroke="currentColor" stroke-width="0.6" fill="none"></path>
  </svg>
  {withWordmark && <span class="font-mono text-lg font-bold">mole</span>}
</a>
