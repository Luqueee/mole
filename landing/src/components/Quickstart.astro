---
import { Badge } from "@/components/ui/badge"
import { CopyButton } from "@/components/CopyButton.tsx"
import { Rocket } from "lucide-react"

const steps = [
  {
    n: 1,
    label: "install",
    cmd: "curl -fsSL https://raw.githubusercontent.com/Luqueee/mole/main/scripts/install.sh | sh",
  },
  {
    n: 2,
    label: "configure + start (interactive; accepts an ssh config alias as the remote)",
    cmd: "mole init",
  },
  {
    n: 3,
    label: "later…",
    cmd: "mole status      # what's forwarded right now\nmole logs -f     # pretty, colourised, live\nmole down        # stop the background daemon",
  },
]
---

<section id="quickstart" data-reveal class="scroll-mt-nav relative py-24">
  <div class="relative z-10 mx-auto max-w-5xl px-6">
    <div class="mb-10 flex flex-col items-center gap-3 text-center">
      <Badge variant="outline" className="gap-1.5">
        <Rocket className="text-primary" />
        Quickstart
      </Badge>
      <h2 class="font-mono text-3xl font-bold text-foreground">
        Running in three commands
      </h2>
      <p class="max-w-2xl text-base text-muted-foreground">
        Three commands. Under a minute from curl to forwarded ports.
      </p>
    </div>

    <div class="relative">
      <div class="pointer-events-none absolute left-0 right-0 top-10 hidden h-px -translate-y-1/2 border-t border-dashed border-border md:block" aria-hidden="true"></div>
      <div class="relative grid grid-cols-1 gap-6 md:grid-cols-3">
        {steps.map((s) => (
          <div class="relative z-10 flex flex-col gap-3 rounded-xl border border-border bg-card p-5">
            <div class="flex items-center gap-3">
              <Badge variant="secondary" className="font-mono">{s.n}</Badge>
              <span class="text-sm text-muted-foreground">{s.label}</span>
            </div>
            <div class="flex items-start justify-between gap-3">
              <pre class="min-w-0 flex-1 whitespace-pre-wrap break-all font-mono text-xs text-foreground"><span class="text-terminal-green">$</span>&nbsp;{s.cmd}</pre>
              <CopyButton client:load text={s.cmd} />
            </div>
          </div>
        ))}
      </div>
    </div>

    <p class="mt-6 text-center text-sm text-muted-foreground">
      <span class="font-mono text-foreground">mole init</span> writes the config,
      then offers to start mole <strong>in the background</strong> for you. From
      there it keeps the tunnel up and forwards new servers as they appear.
    </p>
  </div>
</section>
